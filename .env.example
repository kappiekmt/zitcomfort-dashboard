# ─── META ADS ───────────────────────────────────────────
META_ACCESS_TOKEN=           # Long-lived user or system access token
META_AD_ACCOUNT_ID=          # Format: act_XXXXXXXXXX
META_APP_ID=                 # From Meta for Developers
META_APP_SECRET=             # From Meta for Developers

# ─── GOOGLE ADS ─────────────────────────────────────────
GOOGLE_ADS_CLIENT_ID=        # OAuth2 client ID
GOOGLE_ADS_CLIENT_SECRET=    # OAuth2 client secret
GOOGLE_ADS_REFRESH_TOKEN=    # Long-lived refresh token
GOOGLE_ADS_DEVELOPER_TOKEN=  # From Google Ads API Center
GOOGLE_ADS_CUSTOMER_ID=      # 10-digit customer ID (no dashes)

# ─── GOOGLE ANALYTICS 4 ─────────────────────────────────
GA4_PROPERTY_ID=             # Format: properties/XXXXXXXXX
GA4_CLIENT_EMAIL=            # Service account email
GA4_PRIVATE_KEY=             # Service account private key (use \n for newlines)

# ─── APP ────────────────────────────────────────────────
VITE_API_BASE_URL=           # e.g. http://localhost:3000 for local, blank for Vercel
